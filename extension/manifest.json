{
  "manifest_version": 3,
  "name": "Matara Publisher",
  "version": "1.0.0",
  "description": "פרסום אוטומטי לקבוצות פייסבוק",
  "permissions": ["tabs", "storage", "alarms", "scripting", "notifications"],
  "host_permissions": [
    "https://matara-publisher.vercel.app/*",
    "https://www.facebook.com/*",
    "https://web.facebook.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/groups/joins/*"],
      "js": ["content-groups.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
