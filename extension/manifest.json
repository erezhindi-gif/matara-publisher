{
  "manifest_version": 3,
  "name": "Matara Publisher",
  "version": "2.44.0",
  "description": "פרסום אוטומטי לקבוצות פייסבוק",
  "permissions": ["tabs", "storage", "alarms", "scripting", "notifications", "debugger", "downloads"],
  "host_permissions": [
    "https://matara-publisher.vercel.app/*",
    "https://www.facebook.com/*",
    "https://web.facebook.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
